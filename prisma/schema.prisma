generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserRole {
  ADMIN
  RESPONDER
  VIEWER
}

enum ServiceStatus {
  OPERATIONAL
  DEGRADED
  OUTAGE
  MAINTENANCE
}

enum IncidentSeverity {
  SEV1
  SEV2
  SEV3
  SEV4
}

enum IncidentStatus {
  OPEN
  INVESTIGATING
  MITIGATED
  RESOLVED
  REVIEWED
}

enum TimelineEntryType {
  STATUS_CHANGE
  NOTE
  ASSIGNMENT
  MITIGATION
  ROOT_CAUSE
  ACTION_ITEM_CREATED
}

enum ActionItemStatus {
  OPEN
  IN_PROGRESS
  DONE
  CANCELLED
}

model User {
  id                  String                  @id @default(uuid())
  email               String                  @unique
  name                String
  passwordHash        String
  role                UserRole                @default(RESPONDER)
  createdAt           DateTime                @default(now())
  updatedAt           DateTime                @updatedAt
  assignedIncidents   Incident[]              @relation("IncidentOwner")
  timelineEntries     IncidentTimelineEntry[]
  authoredPostmortems Postmortem[]            @relation("PostmortemAuthor")
  assignedActionItems ActionItem[]            @relation("ActionItemAssignee")
  auditLogs           AuditLog[]

  @@index([role])
}

model Service {
  id          String        @id @default(uuid())
  slug        String        @unique
  name        String
  description String?
  status      ServiceStatus @default(OPERATIONAL)
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt
  incidents   Incident[]

  @@index([status])
}

model Incident {
  id            String                  @id @default(uuid())
  title         String
  summary       String
  severity      IncidentSeverity
  status        IncidentStatus          @default(OPEN)
  serviceId     String
  ownerId       String?
  openedAt      DateTime                @default(now())
  mitigatedAt   DateTime?
  resolvedAt    DateTime?
  reviewedAt    DateTime?
  createdAt     DateTime                @default(now())
  updatedAt     DateTime                @updatedAt
  service       Service                 @relation(fields: [serviceId], references: [id], onDelete: Restrict)
  owner         User?                   @relation("IncidentOwner", fields: [ownerId], references: [id], onDelete: SetNull)
  timeline      IncidentTimelineEntry[]
  postmortem    Postmortem?
  actionItems   ActionItem[]

  @@index([serviceId])
  @@index([ownerId])
  @@index([severity])
  @@index([status])
  @@index([openedAt])
}

model IncidentTimelineEntry {
  id          String            @id @default(uuid())
  incidentId  String
  type        TimelineEntryType
  message     String
  fromStatus  IncidentStatus?
  toStatus    IncidentStatus?
  createdById String
  createdAt   DateTime          @default(now())
  incident    Incident          @relation(fields: [incidentId], references: [id], onDelete: Cascade)
  createdBy   User              @relation(fields: [createdById], references: [id], onDelete: Restrict)

  @@index([incidentId])
  @@index([createdById])
  @@index([createdAt])
}

model Postmortem {
  id                 String       @id @default(uuid())
  incidentId         String       @unique
  authorId           String
  rootCause          String
  impactSummary      String
  detectionSummary   String
  resolutionSummary  String
  lessonsLearned     String
  publishedAt        DateTime?
  createdAt          DateTime     @default(now())
  updatedAt          DateTime     @updatedAt
  incident           Incident     @relation(fields: [incidentId], references: [id], onDelete: Cascade)
  author             User         @relation("PostmortemAuthor", fields: [authorId], references: [id], onDelete: Restrict)
  actionItems        ActionItem[]

  @@index([authorId])
}

model ActionItem {
  id          String           @id @default(uuid())
  incidentId  String
  postmortemId String?
  title       String
  description String?
  status      ActionItemStatus @default(OPEN)
  dueDate     DateTime?
  assigneeId  String?
  createdAt   DateTime         @default(now())
  updatedAt   DateTime         @updatedAt
  incident    Incident         @relation(fields: [incidentId], references: [id], onDelete: Cascade)
  postmortem  Postmortem?      @relation(fields: [postmortemId], references: [id], onDelete: SetNull)
  assignee    User?            @relation("ActionItemAssignee", fields: [assigneeId], references: [id], onDelete: SetNull)

  @@index([incidentId])
  @@index([postmortemId])
  @@index([assigneeId])
  @@index([status])
}

model AuditLog {
  id         String   @id @default(uuid())
  actorId    String
  action     String
  entityType String
  entityId   String
  metadata   Json?
  createdAt  DateTime @default(now())
  actor      User     @relation(fields: [actorId], references: [id], onDelete: Restrict)

  @@index([actorId])
  @@index([entityType, entityId])
  @@index([createdAt])
}

